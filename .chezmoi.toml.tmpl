{{- $is_wsl := false }}
{{ if eq .chezmoi.os "linux" }}
{{   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
{{- $is_wsl = true}}
{{   end }}
{{ end }}
{{- /* Checks if running interactively, which is not the case for GitHub Codespaces */ -}}
{{- $interactive := stdinIsATTY -}}
{{- $name := promptStringOnce . "name" "Name" -}}
{{- $email := promptStringOnce . "email" "Email" -}}
{{- $signingKeyOpReference := promptStringOnce . "signingKeyOpReference" "op:// secret reference" | trimAll "\"" -}}
{{- if $interactive -}}
{{-   writeToStdout "💡 Tip: you can re-enter your name and email with `chezmoi init --data=false`.\n" -}}
{{- end -}}
{{- $computerName := .chezmoi.hostname -}}
{{- if eq .chezmoi.os "darwin" -}}
{{- $computerName = output "scutil" "--get" "ComputerName" | trim -}}
{{- end -}}
{{- $signingKey := onepasswordRead $signingKeyOpReference -}}
sourceDir = "{{ .chezmoi.sourceDir -}}"
[data]
  name = {{ $name | quote}}
  email =  {{ $email | quote }}
  is_wsl = {{ $is_wsl }}
  computer_name = {{ $computerName | quote }}
  os = {{ .chezmoi.os | quote }}
  signingkey = {{ $signingKey | quote }}

[git]
  autoCommit = true
  
[edit]
    command = "code"
    args = ["--wait"]