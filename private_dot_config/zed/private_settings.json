// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
    "ui_font_size": 16.0,
    "buffer_font_weight": 400.0,
    "colorize_brackets": true,
    "completion_menu_item_kind": "symbol",
    "language_models": {
        "opencode": {
            "show_go_models": false,
            "show_zen_models": false,
        },
        "lmstudio": {
            "api_url": "http://localhost:1234/api/v0",
        },
    },
    "which_key": {
        "enabled": true,
    },
    "agent_servers": {
        "github-copilot-cli": {
            "type": "registry",
        },
    },
    "cli_default_open_behavior": "existing_window",
    "buffer_font_size": 12.0,
    "theme": "Monokai Pro (CE)",
    "icon_theme": "Zed (Default)",
    "project_panel": {
        "dock": "right",
    },
    "outline_panel": {
        "dock": "right",
    },
    "collaboration_panel": {
        "dock": "right",
    },
    "git_panel": {
        "dock": "right",
    },
    "ui_font_weight": 400.0,
    "ui_font_family": ".ZedSans",
    "edit_predictions": {
        "allow_data_collection": "no",
        "disabled_globs": [],
        "mode": "eager",
        "copilot": {
            "enable_next_edit_suggestions": true,
        },
        "provider": "zed",
    },
    "buffer_line_height": "standard",
    "git": {
        "inline_blame": {
            "enabled": true,
            "show_commit_summary": false,
        },
    },
    "auto_indent_on_paste": true,
    "wrap_guides": [80],
    "tab_size": 4,
    "autosave": "on_window_change",
    "multi_cursor_modifier": "cmd_or_ctrl",
    "minimap": {
        "show": "always",
        "current_line_highlight": "all",
        "thumb": "always",
    },
    "current_line_highlight": "all",
    "cursor_blink": true,
    "agent": {
        "profiles": {},
        "favorite_models": [
            {
                "provider": "zed.dev",
                "model": "gpt-5-mini",
                "enable_thinking": false,
            },
            {
                "provider": "zed.dev",
                "model": "claude-haiku-4-5",
                "enable_thinking": false,
            },
            {
                "provider": "zed.dev",
                "model": "gpt-5-nano",
                "enable_thinking": false,
            },
            {
                "provider": "zed.dev",
                "model": "gpt-5.5",
                "enable_thinking": true,
                "effort": "medium",
            },
            {
                "provider": "zed.dev",
                "model": "gpt-5.2",
                "enable_thinking": false,
            },
        ],
        "sidebar_side": "left",
        "dock": "left",
        "tool_permissions": {
            "default": "allow",
        },
        "default_profile": "write",
        "button": true,
        "enabled": true,
        "default_model": {
            "enable_thinking": false,
            "provider": "zed.dev",
            "model": "claude-haiku-4-5",
        },
    },
    "base_keymap": "VSCode",
    // "ui_font_size": 14,
    "buffer_font_family": "Berkeley Mono",
    "buffer_font_fallbacks": ["Symbols Nerd Font Mono"],
    "buffer_font_features": { "calt": false },
    "inlay_hints": {
        "enabled": true,
        "show_other_hints": true,
    },
    "tabs": {
        "file_icons": true,
    },
    "languages": {
        "Markdown": {
            "show_edit_predictions": false,
        },
        "Astro": {
            "formatter": "prettier",
        },
        "CSS": {
            "formatter": "prettier",
            "language_servers": [
                "tailwindcss-intellisense-css",
                "!vscode-css-language-server",
            ],
        },
        "HTML": { "formatter": "prettier" },
        "JSON": { "formatter": "prettier" },
        "JSONC": {
            "formatter": "prettier",
        },
        "JavaScript": {
            "formatter": "prettier",
        },

        "TSX": { "formatter": "prettier" },
        "TypeScript": {
            "formatter": "prettier",
        },
    },
    "terminal": {
        "toolbar": {
            "breadcrumbs": false,
        },
        "cursor_shape": "bar",
        "blinking": "on",
        "font_family": "Berkeley Mono",
        "font_size": 12.0,
        "env": {
            "EDITOR": "zed --wait",
            "VISUAL": "zed --wait",
        },
    },
}
