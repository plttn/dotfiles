'$schema' = 'https{{ .chezmoi.pathListSeparator }}{{ .chezmoi.pathSeparator }}{{ .chezmoi.pathSeparator }}jj-vcs.github.io{{ .chezmoi.pathSeparator }}jj{{ .chezmoi.pathSeparator }}latest{{ .chezmoi.pathSeparator }}config-schema.{{ .chezmoi.config.format }}'

[user]
name = "{{ .name }}"
email = "{{ .email }}"

[ui]
default-command = "log"
diff-formatter = ["difft", "--color=always", "$left", "$right"]
show-cryptographic-signatures = true
editor = "nano"


[signing]
behavior = "drop"
backend = "ssh"
key = "{{ .signingkey }} Personal"
backends.ssh.allowed-signers = "~{{ .chezmoi.pathSeparator }}.ssh{{ .chezmoi.pathSeparator }}allowed_signers"


[{{ .chezmoi.config.git.command }}]
sign-on-push = true
write-change-id-header = true

[revsets]
bookmark-advance-to = 'closest_pushable(@)'

[revset-aliases]
# Closest revision that is mutable, described and either non-empty or a merge
'closest_pushable(to)' = '''
  heads({{ .chezmoi.pathListSeparator }}{{ .chezmoi.pathListSeparator }}to & mutable() & ~description(exact{{ .chezmoi.pathListSeparator }}"") & (~empty() | merges()))
'''
